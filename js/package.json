{
  "name": "@vangmay/mycelium",
  "version": "0.1.0",
  "description": "Self-improving memory layer for web agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "myc": "./dist/tools/index.js"
  },
  "files": [
    "dist",
    "explorer/public",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "run:tools": "tsx tools/index.ts",
    "bench": "tsx bench/run-benchmark.ts",
    "explorer": "tsx explorer/server.ts",
    "demo": "tsx demo/run-demo.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod +x dist/tools/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "openai": "^4.0.0",
    "sqlite-vec": "^0.1.9",
    "tsx": "^4.7.0"
  },
  "peerDependencies": {
    "@browserbasehq/sdk": "^2.0.0",
    "playwright": "^1.40.0",
    "playwright-core": "^1.40.0"
  },
  "peerDependenciesMeta": {
    "@browserbasehq/sdk": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "playwright-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "typescript": "^6.0.2"
  }
}
